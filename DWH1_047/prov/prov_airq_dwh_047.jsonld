    {
      "@id": "db://airq/dwh_047/ft_airquality_measurement",
      "@type": "prov:Entity",
      "dct:title": "ft_airquality_measurement",
      "rowCount": 12,
      "dct:description": "Grain: One row per air quality measurement at specific day.",
      "measures": [
        {
          "name": "recordedvalue",
          "agg": "AVG"
        },
        {
          "name": "dataquality",
          "agg": "AVG"
        },
        {
          "name": "datavolumekb",
          "agg": "SUM",
          "fully_additive": true
        },
        {
          "name": "alert_exceeded_flag",
          "agg": "SUM"
        }
      ]
    },
    {
      "@id": "db://airq/dwh_047/ft_service_event",
      "@type": "prov:Entity",
      "dct:title": "ft_service_event",
      "rowCount": 19,
      "dct:description": "Grain: One row per completed service event at one location and day.",
      "measures": [
        {
          "name": "servicecost",
          "agg": "SUM",
          "fully_additive": true
        },
        {
          "name": "durationminutes",
          "agg": "SUM"
        },
        {
          "name": "servicequality",
          "agg": "AVG"
        },
        {
          "name": "underqualified_flag",
          "agg": "SUM"
        }
      ]
    },
